# Banco de Dados (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname?schema=public

# Segurança (OBRIGATÓRIO)
JWT_SECRET=sua_chave_secreta_aqui_muito_longa_e_aleatoria

# Admin (OBRIGATÓRIO)
ADMIN_EMAIL=adm@beend.tech
ADMIN_PASSWORD=sua_senha_forte_aqui

# Admin Settings (frontend)
VITE_ADMIN_EMAILS=adm@beend.tech
VITE_MASTER_ADMIN_EMAILS=adm@beend.tech

# Admin Settings
VITE_ADMIN_EMAILS=adm@beend.tech
VITE_MASTER_ADMIN_EMAILS=adm@beend.tech

# App URL (Usada para links de relatórios em e-mails)
APP_URL=https://seu-dominio.com

# Gmail (Configuração para envio de relatórios automatizados)
GMAIL_USER=seu-email@gmail.com
GMAIL_APP_PASSWORD=sua-senha-de-app-google

# Supabase Storage ("medias" Bucket configuration)
SUPABASE_URL=https://sua-url-do-supabase.supabase.co
SUPABASE_ANON_KEY=sua-chave-anon-ou-service-role-do-supabase
