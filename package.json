    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dexie": "^4.4.2",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
